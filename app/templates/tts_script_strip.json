{
  "template_id": "tts_script_strip",
  "metadata": {
    "name": "TTS文案剥离",
    "description": "固定流程：音频提取、BGM/人声分离、VAD 切分、主说话人筛选、ASR 输出 SRT"
  },
  "nodes": [
    {
      "id": "input_video",
      "type": "VideoInput",
      "label": "加载视频",
      "x": 80,
      "y": 160,
      "status": "idle",
      "inputs": {},
      "outputs": {
        "video_info": {
          "name": "video_info",
          "port_type": "video_info",
          "required": true,
          "description": ""
        }
      },
      "params": {
        "path": {
          "name": "path",
          "param_type": "string",
          "default": "",
          "description": "Video file path",
          "required": true
        }
      }
    },
    {
      "id": "audio_extract",
      "type": "VideoAudioExtract",
      "label": "音频提取",
      "x": 500,
      "y": 160,
      "status": "idle",
      "inputs": {
        "video_info": {
          "name": "video_info",
          "port_type": "video_info",
          "required": true,
          "description": ""
        }
      },
      "outputs": {
        "audio_path": {
          "name": "audio_path",
          "port_type": "file_path",
          "required": true,
          "description": "Extracted audio WAV"
        }
      },
      "params": {
        "audio_format": {
          "name": "audio_format",
          "param_type": "select",
          "default": "wav",
          "description": "",
          "required": false,
          "options": [
            "wav"
          ]
        }
      }
    },
    {
      "id": "vocal_separation",
      "type": "VocalSeparation",
      "label": "BGM/人声分离",
      "x": 920,
      "y": 160,
      "status": "idle",
      "inputs": {
        "audio_path": {
          "name": "audio_path",
          "port_type": "file_path",
          "required": true,
          "description": ""
        }
      },
      "outputs": {
        "vocals_audio": {
          "name": "vocals_audio",
          "port_type": "file_path",
          "required": true,
          "description": "Separated vocals WAV"
        },
        "accompaniment_audio": {
          "name": "accompaniment_audio",
          "port_type": "file_path",
          "required": true,
          "description": "Separated accompaniment WAV"
        },
        "separated_dir": {
          "name": "separated_dir",
          "port_type": "file_path",
          "required": true,
          "description": "Demucs output directory"
        }
      },
      "params": {
        "model": {
          "name": "model",
          "param_type": "select",
          "default": "htdemucs",
          "description": "",
          "required": false,
          "options": [
            "htdemucs",
            "htdemucs_ft",
            "htdemucs_6s",
            "mdx_extra",
            "mdx_extra_q"
          ]
        }
      }
    },
    {
      "id": "voice_vad",
      "type": "VoiceVAD",
      "label": "人声 VAD 切分",
      "x": 1340,
      "y": 160,
      "status": "idle",
      "inputs": {
        "audio_path": {
          "name": "audio_path",
          "port_type": "file_path",
          "required": true,
          "description": ""
        }
      },
      "outputs": {
        "speech_segments_json": {
          "name": "speech_segments_json",
          "port_type": "file_path",
          "required": true,
          "description": "VAD speech segments JSON"
        },
        "speech_segments_dir": {
          "name": "speech_segments_dir",
          "port_type": "file_path",
          "required": true,
          "description": "Directory containing split speech WAV files"
        }
      },
      "params": {
        "vad_model": {
          "name": "vad_model",
          "param_type": "string",
          "default": "ggml-silero-v6.2.0.bin",
          "description": "",
          "required": true
        },
        "vad_threshold": {
          "name": "vad_threshold",
          "param_type": "float",
          "default": 0.25,
          "description": "",
          "required": false
        },
        "min_speech_ms": {
          "name": "min_speech_ms",
          "param_type": "int",
          "default": 10,
          "description": "",
          "required": false
        },
        "min_silence_ms": {
          "name": "min_silence_ms",
          "param_type": "int",
          "default": 50,
          "description": "",
          "required": false
        }
      }
    },
    {
      "id": "dominant_speaker",
      "type": "DominantSpeaker",
      "label": "主说话人筛选",
      "x": 1760,
      "y": 160,
      "status": "idle",
      "inputs": {
        "speech_segments_json": {
          "name": "speech_segments_json",
          "port_type": "file_path",
          "required": true,
          "description": ""
        }
      },
      "outputs": {
        "dominant_segments_json": {
          "name": "dominant_segments_json",
          "port_type": "file_path",
          "required": true,
          "description": "Segments belonging to the dominant speaker"
        },
        "speaker_report_json": {
          "name": "speaker_report_json",
          "port_type": "file_path",
          "required": true,
          "description": "Speaker clustering report"
        },
        "dominant_speaker_id": {
          "name": "dominant_speaker_id",
          "port_type": "json_data",
          "required": true,
          "description": "Selected speaker cluster id"
        }
      },
      "params": {
        "similarity_threshold": {
          "name": "similarity_threshold",
          "param_type": "float",
          "default": 0.82,
          "description": "",
          "required": false
        },
        "pyannote_model": {
          "name": "pyannote_model",
          "param_type": "string",
          "default": "pyannote/wespeaker-voxceleb-resnet34-LM",
          "description": "",
          "required": true
        },
        "hf_token": {
          "name": "hf_token",
          "param_type": "string",
          "default": "",
          "description": "",
          "required": false
        }
      }
    },
    {
      "id": "segment_asr",
      "type": "SegmentASR",
      "label": "ASR 输出 SRT",
      "x": 2180,
      "y": 160,
      "status": "idle",
      "inputs": {
        "segments_json": {
          "name": "segments_json",
          "port_type": "file_path",
          "required": true,
          "description": ""
        }
      },
      "outputs": {
        "srt_content": {
          "name": "srt_content",
          "port_type": "srt_content",
          "required": true,
          "description": "ASR SRT text"
        }
      },
      "params": {
        "whisper_model": {
          "name": "whisper_model",
          "param_type": "string",
          "default": "ggml-large-v3-turbo.bin",
          "description": "",
          "required": true
        },
        "asr_language": {
          "name": "asr_language",
          "param_type": "select",
          "default": "en",
          "description": "",
          "required": false,
          "options": [
            "en",
            "zh",
            "auto"
          ]
        },
        "prompt": {
          "name": "prompt",
          "param_type": "string",
          "default": "",
          "description": "",
          "required": false
        },
        "speaker_filter": {
          "name": "speaker_filter",
          "param_type": "bool",
          "default": true,
          "description": "",
          "required": false
        },
        "speaker_threshold": {
          "name": "speaker_threshold",
          "param_type": "float",
          "default": 0.3,
          "description": "",
          "required": false
        },
        "timing_offset_ms": {
          "name": "timing_offset_ms",
          "param_type": "int",
          "default": 820,
          "description": "",
          "required": false
        }
      }
    }
  ],
  "edges": [
    {
      "source_node_id": "input_video",
      "source_port": "video_info",
      "target_node_id": "audio_extract",
      "target_port": "video_info"
    },
    {
      "source_node_id": "audio_extract",
      "source_port": "audio_path",
      "target_node_id": "vocal_separation",
      "target_port": "audio_path"
    },
    {
      "source_node_id": "vocal_separation",
      "source_port": "vocals_audio",
      "target_node_id": "voice_vad",
      "target_port": "audio_path"
    },
    {
      "source_node_id": "voice_vad",
      "source_port": "speech_segments_json",
      "target_node_id": "dominant_speaker",
      "target_port": "speech_segments_json"
    },
    {
      "source_node_id": "dominant_speaker",
      "source_port": "dominant_segments_json",
      "target_node_id": "segment_asr",
      "target_port": "segments_json"
    }
  ]
}
