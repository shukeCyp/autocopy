# faster-whisper local model. First run downloads the model, later runs reuse cache.
WHISPER_MODEL=Systran/faster-whisper-small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ja
WHISPER_BEAM_SIZE=1
WHISPER_CHUNK_SECONDS=0

# Optional: keep downloaded Whisper models inside this project.
# WHISPER_DOWNLOAD_ROOT=./models/whisper

# Optional: use a Hugging Face mirror when direct download is slow or blocked.
# HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_DISABLE_XET=1
# HF_HUB_ENABLE_HF_TRANSFER=0

# Optional OpenAI-compatible model rewrite endpoint.
# MODEL_API_URL=https://yunwu.ai
# MODEL_API_KEY=
# MODEL_NAME=gemini-3.5-flash

# Optional shot matching backend: hash (default), clip, or transvcl.
# SHOT_SCAN_ENGINE=hash
# For TransVCL, either point at an existing result JSON or provide a command
# that writes {result_file}. The adapter reads TransVCL native JSON segments:
# {"query-ref": [[query_start, ref_start, query_end, ref_end, score]]}
# TRANSVCL_RESULT_FILE=./workspace/transvcl_result.json
# TRANSVCL_COMMAND=python /path/to/TransVCL/run.py --model-file /path/to/model.pth --feat-dir /path/to/features --test-file /path/to/pair_file.csv --save-file {result_file}
